# ──────────────────────────────────────────────────────────────
# FlightRate — Environment Variables
# Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────

# Amadeus for Developers (FREE — 2,000 calls/month)
# 1. Go to: https://developers.amadeus.com
# 2. Sign up (free, no credit card)
# 3. Create a new app → copy Client ID + Client Secret below
# 4. Use "Test" environment — it has real flight schedules

AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# WhatsApp Business Number (international format, no +)
# e.g. 923001234567 for +92 300 1234567
NEXT_PUBLIC_WA_NUMBER=923001234567

# Travelpayouts affiliate marker (public affiliate id, just a number).
# Find it in Travelpayouts dashboard → your Aviasales/flights program.
# When set, a "Book Online" button appears on route + airline pages linking
# to the partner search with your marker. Leave blank to hide the button.
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=
